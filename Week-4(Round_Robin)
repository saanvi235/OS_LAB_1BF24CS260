#include <stdio.h>

int main() {
    int n, i, time = 0, remain, tq;
    int bt[20], rt[20], wt[20], tat[20];
    float avg_wt = 0, avg_tat = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    remain = n;

    for(i = 0; i < n; i++) {
        printf("Enter burst time of P%d: ", i + 1);
        scanf("%d", &bt[i]);
        rt[i] = bt[i];
    }

    printf("Enter time quantum: ");
    scanf("%d", &tq);

    while(remain != 0) {
        for(i = 0; i < n; i++) {
            if(rt[i] > 0 && rt[i] <= tq) {
                time += rt[i];
                wt[i] = time - bt[i];
                rt[i] = 0;
                remain--;
            }
            else if(rt[i] > tq) {
                rt[i] -= tq;
                time += tq;
            }
        }
    }

    printf("\nProcess\tBurstTime\tWaitingTime\tTurnaroundTime\n");

    for(i = 0; i < n; i++) {
        tat[i] = bt[i] + wt[i];
        avg_wt += wt[i];
        avg_tat += tat[i];

        printf("P%d\t%d\t\t%d\t\t%d\n", i + 1, bt[i], wt[i], tat[i]);
    }

    avg_wt = avg_wt / n;
    avg_tat = avg_tat / n;

    printf("\nAverage Waiting Time = %.2f", avg_wt);
    printf("\nAverage Turnaround Time = %.2f\n", avg_tat);

    return 0;
}
